	-	
		var skillsItems = [
			{group:"Frontend", technology:[
				{picture: "html", desc: "Владение HTML. Семантичная и валидная верстка"},
				{picture: "css", desc: "Владение CSS. Умение использовать возможности CSS3"},
				{picture: "js", desc: "Основы JavaScript, базовые операции с объектами и массивами"},
				{picture: "jquery", desc: "Написания простых виджетов, работа и настройка плагинов"},
				{picture: "bootstrap", desc: "Работа с модулями и сеткой фреймворка bootstrap"},	
				{picture: "flexbox", desc: "Верстка лейаута с применением свойств flexbox"},
				{picture: "adaptiv", desc: "Адаптивная верстка с использованием медиа запросов"},
				{picture: "browser", desc: "Кроссбраузерная верстка под браузеры популярных движков"},
				{picture: "ps", desc: "Знание Photoshop на уровне 'нарезания' макетов"},
				{picture: "bem", desc: "Понимание модульной верстки, именование классов по БЭМ"},
				{picture: "svg", desc: "Навыки работы c векторной графикой в формате SVG"},
				{picture: "retina", desc: "Умение работать с графикой на сайте под retina дисплеи"},
				{picture: "yandex", desc: "Работа с JS API HTML5, работа с картами google/yandex"},
				{picture: "ajax", desc: "Работа с технологией Ajax, асинхронные запросы на сервер"}

			]},
			{group:"Backend", technology:[
				{picture:"node" ,desc: "Работа с Node.js, настройка роутинга сайта"},
				{picture:"mongo" ,desc: "Работа с MongoDB, сохранение данных с помощью Ajax"}
			]},
			{group:"WorkFlow", technology:[
				{picture:"sass" ,desc: "Работа с SASS и инструментами его компиляции"},
				{picture:"pug" ,desc: "Работа с препроцессором и шаблонизатором Pug"},
				{picture:"npm" ,desc: "Работа с консолью на уровне основных команд и npm"},
				{picture:"gulp" ,desc: "Сборка и оптимизация проекта при помощи GULP и его плагинов"},
				{picture:"brsync" ,desc: "Работа с browser-sync, использование преимуществ livereload"},
				{picture:"git" ,desc: "Работа с системами контроля версий (GIT (github))"},
				{picture:"dev" ,desc: " Работа с полезными расширениями Chrome: PerfectPixel, Web Developer  и т.д."},
