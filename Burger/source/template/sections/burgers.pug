-   
    var ingridients = [
        {icon:"beef", title:"Говядина", amount:"300 г"},
        {icon:"buns", title:"Булочки", amount:"100 г"},
        {icon:"salad", title:"Зелень", amount:"70 г"},
        {icon:"sauce", title:"Соус", amount:"150 г"},
        {icon:"cucumber", title:"Овощи", amount:"200 г"},
        {icon:"cheese", title:"Сыр", amount:"80 г"},
    ]
section.burgers#burgers
    .container
        ul.burgers__list.owl-carousel
            each burgerItem in burgers
                li.burgers__item                       
                    .burgers__pic
                        .burgers__consist
                            .burgers__consist-icon 
                                .burgers__consist-pic
                                    svg.burgers__consist-img
                                        use(xlink:href=`./img/sprite.svg#burger`) 
                                .burgers__consist-text Состав
                            .burgers__consist-ingridient 
                                table.ingridient-table
                                    each ingridient in ingridients
                                        tr.ingridient-table__row
                                            td.ingridient-table__cell
                                                svg.ingridient-table__cell-icon
                                                    use(xlink:href=`./img/sprite.svg#${ingridient.icon}`) 
                                            td.ingridient-table__cell= ingridient.title
                                            td.ingridient-table__cell= ingridient.amount
                        .burgers__weight
                            .burgers__weight-amount 1200
                            .burgers__weight-text ккал   
                        img.burgers__img(src=`./img/${burgerItem.pic}`, alt=`${burgerItem.title}`)
                    .burgers__desc 
                        h3.section__title.burgers__title= burgerItem.title 
                        .section__text.burgers__text
                            p= burgerItem.desc
                        .burgers__cost
                            .burgers__price 
                                .burgers__price-amount 500
                                .burgers__price-text рублей
                            .burgers__order-btn 
                                a.btn(data-index="7" href="#7") Заказать     

