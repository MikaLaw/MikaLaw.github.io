mixin navigation(activeItem)
    -   
        var menuItems = [
                {icon: "fa-solid fa-user-secret", text: "Обо мне", link: "about.html"},
                {icon: "fa-solid fa-rocket", text: "Карьерный путь", link: "career.html"},
                {icon: "fa-solid fa-briefcase", text: "Портфолио", link: "portfolio.html"},
            ]
    aside.sidebar
        nav.nav
            ul.nav__list 
                each item in menuItems
                    li(class=`nav__items${activeItem == item.link ? " active" : ""}` )
                        a.nav__link(href=`${item.link}`)
                            i.nav__link-icon(class=`${item.icon}`)
                            span.nav__link-text= item.text
                            
