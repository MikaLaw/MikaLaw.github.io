        .form-content
            .form__wrap#form-block
                .form__wrap-title
                    h2.section__title Закажи сейчас
                .form__wrap-content
                    form.form#form(action="#")
                        .form__row
                            input.form__input(name="name", type="text", placeholder="Введите ваше Имя", required) 
                        .form__row
                            input.form__input(name="email", type="email", placeholder="Введите ваш Email", required) 
                        .form__row
                            input.form__input#form__input-phone(name="phone", type="tel", required, placeholder="8 (___) ___-__-__")  
                        .form__row
                            input.form__checkbox(name="call", type="checkbox", id="call-order") 
                            label.form__label(for="call-order") Заказать обратный звонок 
                        .form__row.form__row--btn     
                            button.form__btn(type="submit") 
                                                   
