-   
    var quoteItems = [
        {text: "“Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.”", name:"Jon Doe"},     
        {text: "“Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.”", name:"Jon Doe"},  
        {text: "“Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.”", name:"Jon Doe"},  
    ];

section.quote
    .container 
        ul.quote__list.quote__list-one.owl-carousel.owl-theme.wow.animate__fadeIn(data-wow-duration="1.2s") 
            each quoteItem in quoteItems
                li.quote__item
                    .quote__pic 
                        svg.quote__icon
                            use(xlink:href=`./img/sprite.svg#quote-one-speech`)
                    .quote__desc
                        blockquote.quote__text= quoteItem.text 
                        .quote__name= quoteItem.name
