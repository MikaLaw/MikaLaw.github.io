    ];

section.review 
    .container
        .wow.animate__fadeInUp(data-wow-duration="1.2s") 
            +sectionTitle("Happy Clients", "What people say", "review__title")
        ul.review__list
            each reviewItem in reviewItems
                li.review__item
                    .review__avatar 
                        .review__pic
                            img.section__img(src=`./img/${reviewItem.img}.jpg`, alt=`${reviewItem.name}`)
                    .review__desc
                        .review__desc-title 
                            .review__desc-name= reviewItem.name 
                            .review__desc-proff= reviewItem.proff 
                        .review__desc-text= reviewItem.text